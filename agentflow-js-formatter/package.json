{
  "name": "agentflow-js-formatter",
  "displayName": "Agentflow JS Formatter",
  "description": "自動格式化 .js 檔案，支援自訂 {KEY:} 語法保留與多餘空行壓縮",
  "version": "0.1.0",
  "publisher": "agentflow",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Formatter"],
  "activationEvents": ["onLanguage:javascript"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{ "id": "javascript" }],
    "commands": []
  },
  "scripts": {
    "compile": "tsc -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js",
    "package": "vsce package"
  },
  "dependencies": {
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.0.0",
    "mocha": "^10.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0"
  },
  "vsce": {
    "dependencies": true
  }
}
